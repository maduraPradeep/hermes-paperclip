# Public hostnames — must already point at this host's public IP via DNS
# before you run ./init-letsencrypt.sh.
HERMES_DOMAIN=hermes.example.com
PAPERCLIP_DOMAIN=paperclip.example.com
WORKSPACE_DOMAIN=workspace.example.com

# Email used by Let's Encrypt for expiry notices (required, not published).
LE_EMAIL=admin@example.com

# Set to 1 while testing to use Let's Encrypt's staging environment
# (untrusted certs, but no rate limit). Leave at 0 for real certs.
LE_STAGING=0

# Hermes Workspace authentication — required when the UI is not on localhost.
# Set a strong password; this gates the workspace login screen.
HERMES_PASSWORD=changeme
# If you set API_SERVER_KEY on the hermes service, set the same value here.
# Leave blank if the gateway runs without auth (the default).
HERMES_API_TOKEN=

# Map Hermes' in-container UID/GID to your host user so files written to
# ./data/hermes are owned by you, not by UID 10000.
HERMES_UID=1000
HERMES_GID=1000
